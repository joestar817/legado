<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Ng.DialogRoot"
    android:layout_height="match_parent">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/tool_bar"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:background="@android:color/transparent"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        app:popupTheme="@style/AppTheme.PopupOverlay"
        app:titleTextAppearance="@style/ToolbarTitle"
        app:titleTextColor="@color/ng_on_surface" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/ng_dialog_padding"
        android:layout_marginEnd="@dimen/ng_dialog_padding"
        android:layout_weight="1"
        android:background="@drawable/ng_bg_dialog_section">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:scrollbars="none"
            tools:ignore="SpeakableTextPresentCheck" />

    </FrameLayout>

    <LinearLayout
        style="@style/Ng.DialogActionBar">

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <io.legado.app.ui.widget.text.AccentStrokeTextView
            android:id="@+id/tv_cancel"
            style="@style/Ng.DialogButton.Secondary"
            android:layout_height="42dp"
            android:minWidth="88dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="@string/cancel"
            android:textSize="15sp"
            tools:ignore="RtlHardcoded" />

        <io.legado.app.ui.widget.text.AccentBgTextView
            android:id="@+id/tv_ok"
            style="@style/Ng.DialogButton.Primary"
            android:layout_height="42dp"
            android:layout_marginStart="10dp"
            android:minWidth="88dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="@string/ok"
            android:textSize="15sp"
            tools:ignore="RtlHardcoded" />

    </LinearLayout>
</LinearLayout>

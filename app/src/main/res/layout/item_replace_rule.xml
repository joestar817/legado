<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/section_container"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/ng_bg_replace_rule_section"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="2dp">

        <io.legado.app.lib.theme.view.ThemeCheckBox
            android:id="@+id/cb_section"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:buttonTint="@color/tv_text_summary"
            android:contentDescription="@string/select_all"
            android:gravity="center"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/view_section_status"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginStart="3dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toRightOf="@id/cb_section"
            app:layout_constraintTop_toTopOf="parent"
            tools:background="@color/success" />

        <TextView
            android:id="@+id/tv_section_title"
            style="@style/Ng.CardTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toRightOf="@id/view_section_status"
            app:layout_constraintRight_toLeftOf="@id/tv_section_count"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="本地/书籍 · 你个妖怪还想去西游？ 作者：我真不是小号" />

        <TextView
            android:id="@+id/tv_section_count"
            style="@style/Ng.Summary"
            android:layout_width="wrap_content"
            android:layout_height="20dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="2dp"
            android:background="@drawable/ng_bg_replace_rule_badge"
            android:gravity="center"
            android:minWidth="28dp"
            android:paddingStart="7dp"
            android:paddingEnd="7dp"
            android:singleLine="true"
            android:textSize="10sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintRight_toLeftOf="@id/iv_section_more"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="18 条" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_section_more"
            android:layout_width="26dp"
            android:layout_height="28dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/more_menu"
            android:padding="4dp"
            android:src="@drawable/ic_more_vert"
            android:tint="@color/primaryText"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintRight_toLeftOf="@id/iv_section_expand"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_section_expand"
            android:layout_width="22dp"
            android:layout_height="24dp"
            android:padding="4dp"
            android:src="@drawable/ic_arrow_down"
            android:tint="@color/tv_text_summary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/rule_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:minHeight="52dp"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <io.legado.app.lib.theme.view.ThemeCheckBox
            android:id="@+id/cb_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:singleLine="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toLeftOf="@+id/view_rule_status"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="RtlSymmetry"
            tools:text="AI净化：看着树洞里这 4 条" />

        <View
            android:id="@+id/view_rule_status"
            android:layout_width="7dp"
            android:layout_height="7dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintRight_toLeftOf="@+id/iv_menu_more"
            app:layout_constraintTop_toTopOf="parent"
            tools:background="@color/success" />

        <TextView
            android:id="@+id/tv_rule_meta"
            style="@style/Ng.Summary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="4dp"
            android:singleLine="true"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toLeftOf="@+id/iv_menu_more"
            app:layout_constraintTop_toBottomOf="@id/cb_name"
            tools:text="正文 · 普通替换 · 已启用" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_menu_more"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/more_menu"
            android:padding="6dp"
            android:src="@drawable/ic_more_vert"
            android:tint="@color/primaryText"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="RtlHardcoded" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</LinearLayout>
